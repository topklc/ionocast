# LaTeX build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz

# Cloudflare Wrangler
.wrangler/

# Node
node_modules/
package.json
package-lock.json

# Local pre-change backups (revert anchors)
_physics-backup-*/

# Calibration / harness ephemera (gitignored cache; committed inputs in
# scripts/data/ are not affected, e.g. paths.json, harness.baseline*.json)
scripts/data/.cache/
scripts/outputs/

# Tropo sandbox output: grid.json / grid.bin are regenerated by
# src/tropo/ingest.mjs + pack-binary.mjs (locally) or by the
# tropo-ingest GitHub Actions workflow + R2 (production).  GRIB
# cache is the raw GFS download, also regeneratable.
src/tropo/data/grid*.json
src/tropo/data/grid*.bin
src/tropo/data/.grib-cache/

# OS
.DS_Store
Thumbs.db
*~
*.bak
